# Database — SQLite by default (no external DB needed). Switch via DB_DRIVER +
# a DB provider plugin (postgres, mysql, …).
DB_DRIVER=sqlite
DATABASE_URL=file:./togo.db?_pragma=foreign_keys(1)&_time_format=sqlite

# HTTP
ADDR=:8080

# Logging
LOG_LEVEL=info
LOG_FORMAT=text

# Supabase auth (optional; used by plugin-auth-supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=
