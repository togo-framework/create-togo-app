// Package app is the application container (Laravel-style): shared services
// wired once and handed to controllers, resolvers, actions, and seeders.
package app

import (
	"context"
	"database/sql"
	"log/slog"

	"github.com/togo-framework/togo"
	"github.com/togo-framework/togo/orm"
	_ "modernc.org/sqlite" // default DB driver (SQLite). DB provider plugins register others.

	db "{{.Module}}/internal/db/gen"
)

// App holds the shared services. Add cache/queue/storage here as you adopt them.
type App struct {
	Kernel  *togo.Kernel
	DB      *db.Queries  // sqlc typed queries (for complex/typed SQL)
	SQLDB   *sql.DB      // raw handle used by the ORM
	Dialect orm.Dialect  // driver-specific SQL dialect (from DB_DRIVER)
	Hooks   *togo.Hooks
	Log     *slog.Logger
}

// New builds the container from the kernel, opening the DB if configured.
func New(ctx context.Context, k *togo.Kernel) *App {
	a := &App{Kernel: k, Hooks: k.Hooks, Log: k.Log, Dialect: k.Dialect()}
	if sqlDB, err := k.SQL(ctx); err == nil {
		a.SQLDB = sqlDB
		a.DB = db.New(sqlDB)
	} else {
		k.Log.Warn("database unavailable", "err", err)
	}
	return a
}
