{{- if eq .DB "sqlite" -}}
# SQLite needs no services — the database is an embedded file (see DATABASE_URL).
# To use a docker-backed database, recreate with:
#   togo new {{.App}} --db postgres|togo-postgres|supabase|mysql|mongodb
{{- else if eq .DB "postgres" -}}
services:
  postgres:
    image: postgres:16
    container_name: {{.App}}-postgres
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: {{.App}}
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5

volumes:
  pgdata:
{{- else if eq .DB "togo-postgres" -}}
# togo-postgres — batteries-included Postgres (pg_duckdb, pg_search/BM25, pgvector,
# pg_cron, pg_partman) + Supabase-role compat. NATS JetStream is the MQ.
# Image: ghcr.io/togo-framework/db (github.com/togo-framework/db)
services:
  postgres:
    image: ghcr.io/togo-framework/db:latest
    container_name: {{.App}}-pg
    command:
      - postgres
      - -c
      - shared_preload_libraries=pg_cron,pg_duckdb,pg_search
      - -c
      - cron.database_name={{.App}}
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: {{.App}}
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5

  nats:
    image: nats:2          # NATS JetStream — message queue
    container_name: {{.App}}-nats
    command: ["-js"]
    ports:
      - "4222:4222"
      - "8222:8222"

  gotrue:
    image: supabase/gotrue:v2.151.0
    container_name: {{.App}}-gotrue
    depends_on:
      postgres:
        condition: service_healthy
    ports:
      - "9999:9999"
    environment:
      GOTRUE_API_HOST: 0.0.0.0
      GOTRUE_API_PORT: "9999"
      GOTRUE_DB_DRIVER: postgres
      GOTRUE_DB_DATABASE_URL: "postgres://supabase_auth_admin:postgres@postgres:5432/{{.App}}?search_path=auth"
      GOTRUE_SITE_URL: http://localhost:3000
      GOTRUE_JWT_SECRET: "super-secret-jwt-token-replace-in-production"
      GOTRUE_JWT_EXP: "3600"
      API_EXTERNAL_URL: http://localhost:9999

  storage:
    image: supabase/storage-api:v1.11.6
    container_name: {{.App}}-storage
    depends_on:
      postgres:
        condition: service_healthy
    ports:
      - "5000:5000"
    environment:
      ANON_KEY: "your-anon-key"
      SERVICE_KEY: "your-service-key"
      POSTGREST_URL: http://localhost:3000
      PGRST_JWT_SECRET: "super-secret-jwt-token-replace-in-production"
      DATABASE_URL: "postgres://supabase_storage_admin:postgres@postgres:5432/{{.App}}"
      FILE_SIZE_LIMIT: "52428800"
      STORAGE_BACKEND: file
      FILE_STORAGE_BACKEND_PATH: /var/lib/storage
      TENANT_ID: stub
      REGION: local
      GLOBAL_S3_BUCKET: stub
    volumes:
      - storagedata:/var/lib/storage

volumes:
  pgdata:
  storagedata:
{{- else if eq .DB "supabase" -}}
# Supabase local stack. This compose runs the database; for the FULL managed stack
# (GoTrue + Storage + Studio + Realtime + Kong) install the Supabase CLI and run
# `supabase start` in this directory. Commented services below are placeholders.
services:
  postgres:
    image: supabase/postgres:15.1.1.78
    container_name: {{.App}}-supabase-db
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: postgres
    ports:
      - "5432:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 5

  # studio:   # Supabase Studio — use `supabase start` for the wired-up dashboard
  #   image: supabase/studio:latest
  #   ports: ["54323:3000"]

volumes:
  pgdata:
{{- else if eq .DB "mysql" -}}
services:
  mysql:
    image: mysql:8
    container_name: {{.App}}-mysql
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: {{.App}}
    ports:
      - "3306:3306"
    volumes:
      - mysqldata:/var/lib/mysql
    healthcheck:
      test: ["CMD-SHELL", "mysqladmin ping -h localhost -proot"]
      interval: 5s
      timeout: 5s
      retries: 5

volumes:
  mysqldata:
{{- else if eq .DB "mongodb" -}}
services:
  mongodb:
    image: mongo:7
    container_name: {{.App}}-mongo
    environment:
      MONGO_INITDB_ROOT_USERNAME: root
      MONGO_INITDB_ROOT_PASSWORD: root
    ports:
      - "27017:27017"
    volumes:
      - mongodata:/data/db

volumes:
  mongodata:
{{- end}}
