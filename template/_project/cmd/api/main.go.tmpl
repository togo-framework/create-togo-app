// Command api is the {{.App}} HTTP entrypoint: chi router + Huma (REST/OpenAPI).
// GraphQL (gqlgen) mounts alongside once you run `togo generate`.
package main

import (
	"fmt"
	"net/http"
	"os"

	"github.com/danielgtaylor/huma/v2"
	"github.com/danielgtaylor/huma/v2/adapters/humachi"
	"github.com/go-chi/chi/v5"

	"{{.Module}}/internal/rest"
)

func main() {
	if len(os.Args) > 1 && os.Args[1] == "openapi" {
		dumpOpenAPI()
		return
	}

	router := chi.NewMux()
	api := humachi.New(router, huma.DefaultConfig("{{.AppPascal}} API", "0.1.0"))

	// Mount every generated resource's REST routes (regenerated by togo).
	rest.RegisterRoutes(api)

	addr := envOr("ADDR", ":8080")
	fmt.Printf("→ {{.App}} listening on %s (docs at /docs)\n", addr)
	if err := http.ListenAndServe(addr, router); err != nil {
		panic(err)
	}
}

// dumpOpenAPI prints the generated OpenAPI 3.1 document — used by `togo generate`.
func dumpOpenAPI() {
	router := chi.NewMux()
	api := humachi.New(router, huma.DefaultConfig("{{.AppPascal}} API", "0.1.0"))
	rest.RegisterRoutes(api)
	b, err := api.OpenAPI().YAML()
	if err != nil {
		panic(err)
	}
	os.Stdout.Write(b)
}

func envOr(key, def string) string {
	if v := os.Getenv(key); v != "" {
		return v
	}
	return def
}
