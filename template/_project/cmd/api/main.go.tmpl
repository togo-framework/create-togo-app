// Command api is the {{.App}} HTTP entrypoint. It builds the togo kernel and
// mounts both interfaces on it: Huma (REST + OpenAPI) and gqlgen (GraphQL).
package main

import (
	"context"
	"fmt"
	"net/http"
	"os"

	"github.com/99designs/gqlgen/graphql/handler"
	"github.com/99designs/gqlgen/graphql/playground"
	"github.com/danielgtaylor/huma/v2"
	"github.com/danielgtaylor/huma/v2/adapters/humachi"
	"github.com/go-chi/chi/v5"
	"github.com/togo-framework/togo"

	graphgen "{{.Module}}/internal/graph/gen"
	"{{.Module}}/internal/graph/resolvers"
	"{{.Module}}/internal/rest"
)

func main() {
	if len(os.Args) > 1 && os.Args[1] == "openapi" {
		dumpOpenAPI()
		return
	}

	k := togo.New()

	// REST + OpenAPI (Huma) mounted on the kernel's chi router.
	api := humachi.New(k.Router, huma.DefaultConfig("{{.AppPascal}} API", "0.1.0"))
	rest.RegisterRoutes(api)

	// GraphQL (gqlgen).
	gql := handler.NewDefaultServer(graphgen.NewExecutableSchema(graphgen.Config{
		Resolvers: &resolvers.Resolver{},
	}))
	k.Router.Handle(k.Config.GraphQLPath, gql)
	k.Router.Handle("/graphql/play", playground.Handler("{{.AppPascal}} GraphQL", k.Config.GraphQLPath))

	// Always-on health endpoint (the frontend dashboard pings this).
	k.Router.Get("/api/health", func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		_, _ = w.Write([]byte(`{"status":"ok","service":"{{.App}}"}`))
	})

	fmt.Printf("→ {{.App}} listening on %s  (GraphQL %s · REST %s · docs %s)\n",
		k.Config.Addr, k.Config.GraphQLPath, k.Config.RESTPath, k.Config.DocsPath)
	defer k.Close()
	if err := k.Serve(context.Background()); err != nil {
		panic(err)
	}
}

// dumpOpenAPI prints the generated OpenAPI 3.1 document — used by `togo generate`.
func dumpOpenAPI() {
	router := chi.NewMux()
	api := humachi.New(router, huma.DefaultConfig("{{.AppPascal}} API", "0.1.0"))
	rest.RegisterRoutes(api)
	b, err := api.OpenAPI().YAML()
	if err != nil {
		panic(err)
	}
	os.Stdout.Write(b)
}
