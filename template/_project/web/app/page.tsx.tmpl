"use client";

import { useEffect, useState } from "react";

// Welcome screen — minimal & creative. Links into the auth/dashboard plugin
// (login → create account → dashboard) and shows the live togo version.
export default function Welcome() {
  const [health, setHealth] = useState<{ status?: string; togo?: string } | null>(null);

  useEffect(() => {
    const api = process.env.NEXT_PUBLIC_API_ORIGIN ?? "";
    fetch(`${api}/api/health`).then((r) => r.json()).then(setHealth).catch(() => setHealth(null));
  }, []);

  return (
    <main className="flex min-h-screen flex-col items-center justify-center bg-gradient-to-br from-slate-950 via-slate-900 to-indigo-950 px-6 text-white">
      <div className="w-full max-w-md text-center">
        <div className="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-400 to-violet-500 text-3xl font-bold shadow-lg shadow-indigo-500/30">
          t
        </div>

        <h1 className="bg-gradient-to-r from-indigo-300 to-violet-400 bg-clip-text text-5xl font-extrabold tracking-tight text-transparent">
          {{.AppPascal}}
        </h1>
        <p className="mt-3 text-slate-400">Built with togo — sign in to your dashboard.</p>

        <div className="mt-10 space-y-3">
          <a href="/login" className="block w-full rounded-xl bg-white py-3 font-semibold text-slate-900 transition hover:bg-slate-200">
            Log in
          </a>
          <a href="/register" className="block w-full rounded-xl border border-slate-700 py-3 font-semibold text-white transition hover:bg-white/5">
            Create account
          </a>
          <a href="/dashboard" className="block pt-2 text-sm text-slate-500 underline-offset-4 hover:text-slate-300 hover:underline">
            Go to dashboard →
          </a>
        </div>

        <div className="mt-12 flex items-center justify-center gap-4 text-xs text-slate-500">
          <span className="inline-flex items-center gap-1.5">
            <span className={`h-2 w-2 rounded-full ${health?.status === "ok" ? "bg-emerald-400" : "bg-slate-600"}`} />
            API {health?.status === "ok" ? "connected" : "offline"}
          </span>
          <span>·</span>
          <a href="/docs" className="hover:text-slate-300">REST docs</a>
          <span>·</span>
          <a href="/graphql/play" className="hover:text-slate-300">GraphQL</a>
        </div>
        <p className="mt-4 text-xs text-slate-600">togo {health?.togo ?? "…"} · powered by Go</p>
      </div>
    </main>
  );
}
