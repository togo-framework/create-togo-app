# The Go API origin the Next.js dev server proxies /api and /graphql to.
# togo serve sets this automatically; override here if your API runs elsewhere.
API_ORIGIN=http://localhost:8080

# Public base URL used by the browser client (defaults to same-origin /api).
NEXT_PUBLIC_API_URL=/api

# Supabase (auth + storage). Get these from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
